---
/**
 * Structured data (JSON-LD) for SEO + AEO.
 * Everything here mirrors visible page content (schema-content parity, item 51).
 */
import { checklist, allItems } from '../data/checklist';

const { site, org, faq } = checklist;
const base = site.url;

const organization = {
  '@type': 'Organization',
  '@id': `${org.url}#organization`,
  name: org.name,
  url: org.url,
  logo: org.logo,
  sameAs: org.sameAs,
};

const webpage = {
  '@type': 'TechArticle',
  '@id': `${base}#article`,
  headline: 'The Ultimate Webflow SEO & AEO Checklist',
  description: site.description,
  inLanguage: site.locale,
  datePublished: site.updated,
  dateModified: site.updated,
  mainEntityOfPage: base,
  author: { '@id': `${org.url}#organization` },
  publisher: { '@id': `${org.url}#organization` },
  keywords: site.keywords.join(', '),
};

const howTo = {
  '@type': 'HowTo',
  name: 'How to do Webflow SEO & AEO before launch',
  description:
    'A page-by-page method for optimising a Webflow site for search engines and AI answer engines, in 52 steps across 7 phases.',
  step: allItems.map((item) => ({
    '@type': 'HowToStep',
    position: item.n,
    name: item.title,
    text: item.summary,
    url: `${base}#${item.id}`,
  })),
};

const faqPage = {
  '@type': 'FAQPage',
  '@id': `${base}#faq`,
  mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const breadcrumb = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Milk Moon Studio', item: org.url },
    { '@type': 'ListItem', position: 2, name: 'Webflow SEO & AEO Checklist', item: base },
  ],
};

const graph = {
  '@context': 'https://schema.org',
  '@graph': [organization, webpage, howTo, faqPage, breadcrumb],
};
---

<script type="application/ld+json" set:html={JSON.stringify(graph)} is:inline />
