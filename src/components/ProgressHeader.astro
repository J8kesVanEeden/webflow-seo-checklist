---
import { totalItems } from '../data/checklist';
---

<header class="topbar" id="top">
  <div class="container topbar__inner">
    <a href="#top" class="topbar__brand" aria-label="Webflow SEO & AEO Checklist — back to top">
      <span class="topbar__brand-mark" aria-hidden="true">◖</span>
      <span>Webflow SEO &amp; AEO Checklist</span>
    </a>

    <div class="topbar__progress" role="status" aria-live="polite">
      <span class="ring" aria-hidden="true">
        <svg viewBox="0 0 36 36" width="34" height="34">
          <circle class="ring__track" cx="18" cy="18" r="14" />
          <circle class="ring__fill js-ring" cx="18" cy="18" r="14"
            stroke-dasharray="87.96" stroke-dashoffset="87.96" />
        </svg>
        <span class="ring__pct js-pct">0%</span>
      </span>
      <span class="topbar__count">
        <strong class="js-done">0</strong><span class="topbar__sep">/</span><span class="js-total">{totalItems}</span>
        <span class="topbar__count-label">done</span>
      </span>
      <button type="button" class="topbar__reset js-reset" aria-label="Reset all progress">Reset</button>
    </div>
  </div>
  <div class="topbar__bar" aria-hidden="true"><span class="topbar__fill js-fill"></span></div>
</header>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--black) 88%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border);
  }
  .topbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4rem;
    padding-block: 0.6rem;
  }
  .topbar__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-display);
    font-size: clamp(1rem, 2.2vw, 1.4rem);
    color: var(--white);
    text-decoration: none;
    line-height: 1;
  }
  .topbar__brand-mark { color: var(--lilac); font-size: 1.1em; }

  .topbar__progress { display: inline-flex; align-items: center; gap: 0.85rem; }

  .ring { position: relative; display: inline-grid; place-items: center; width: 34px; height: 34px; flex: none; }
  .ring svg { transform: rotate(-90deg); }
  .ring__track { fill: none; stroke: var(--grey-dark); stroke-width: 3.2; }
  .ring__fill {
    fill: none;
    stroke: var(--lilac);
    stroke-width: 3.2;
    stroke-linecap: round;
    transition: stroke-dashoffset 0.5s var(--ease);
  }
  .ring__pct {
    position: absolute;
    font-size: 0.5rem;
    font-weight: 600;
    color: var(--text-dim);
    letter-spacing: -0.02em;
  }

  .topbar__count { font-size: 0.9rem; color: var(--text-faint); white-space: nowrap; }
  .topbar__count .js-done { color: var(--white); font-weight: 600; }
  .topbar__sep { margin: 0 0.1rem; }
  .topbar__count-label { margin-left: 0.3rem; }

  .topbar__reset {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-faint);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.38rem 0.8rem;
    transition: color 0.18s var(--ease), border-color 0.18s var(--ease);
  }
  .topbar__reset:hover { color: var(--white); border-color: var(--border-strong); }

  .topbar__bar { height: 2px; background: var(--grey-dark); }
  .topbar__fill {
    display: block;
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--purple), var(--lilac));
    transition: width 0.5s var(--ease);
  }

  @media (max-width: 600px) {
    .topbar__count-label { display: none; }
    .topbar__brand span:last-child { display: none; }
    .topbar__brand-mark { font-size: 1.5rem; }
  }
</style>
