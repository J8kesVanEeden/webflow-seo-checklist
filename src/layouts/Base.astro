---
import { checklist } from '../data/checklist';
import Schema from '../components/Schema.astro';
import '../styles/global.css';

const { site } = checklist;
const canonical = new URL(Astro.url.pathname, site.url).href.replace(/\/$/, '') || site.url;
const ogImage = new URL(site.ogImage, site.url).href;
const GTM_ID = 'GTM-P29ZKG79';
---

<!doctype html>
<html lang={site.locale}>
  <head>
    <!-- Google Tag Manager -->
    <script is:inline define:vars={{ GTM_ID }}>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != 'dataLayer' ? '&l=' + l : '';
        j.async = true;
        j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, 'script', 'dataLayer', GTM_ID);
    </script>
    <!-- End Google Tag Manager -->

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{site.title}</title>
    <meta name="description" content={site.description} />
    <meta name="keywords" content={site.keywords.join(', ')} />
    <meta name="author" content={site.author} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content={site.author} />
    <meta property="og:title" content={site.title} />
    <meta property="og:description" content={site.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={site.title} />
    <meta name="twitter:description" content={site.description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Icons -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#0c0c0c" />

    <!-- Preload critical fonts -->
    <link rel="preload" href="/fonts/Durer.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Poppins-Regular.woff2" as="font" type="font/woff2" crossorigin />

    <Schema />
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-P29ZKG79"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
        title="Google Tag Manager"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->

    <a class="skip-link" href="#main">Skip to content</a>
    <slot />
  </body>
</html>

<style is:global>
  .skip-link {
    position: absolute;
    left: 0.75rem;
    top: -3rem;
    z-index: 200;
    background: var(--lilac);
    color: var(--black);
    padding: 0.55rem 0.9rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.85rem;
    transition: top 0.2s var(--ease);
  }
  .skip-link:focus { top: 0.75rem; }
</style>
