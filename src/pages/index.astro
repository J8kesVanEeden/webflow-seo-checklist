---
import Base from '../layouts/Base.astro';
import ProgressHeader from '../components/ProgressHeader.astro';
import ChecklistItem from '../components/ChecklistItem.astro';
import FAQ from '../components/FAQ.astro';
import { checklist } from '../data/checklist';

const { hero, howToUse, phases, doFirst, sources, about, site } = checklist;
const dataSources = sources.filter((s) => s.kind === 'data');
const readingSources = sources.filter((s) => s.kind !== 'data');
const updated = new Date(site.updated).toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<Base>
  <ProgressHeader />

  <main id="main">
    <!-- ================= HERO ================= -->
    <section class="hero">
      <div class="container">
        <img class="hero__star" src="/brand/star.svg" alt="" aria-hidden="true" width="38" height="38" />
        <p class="eyebrow hero__eyebrow">{hero.eyebrow} · Updated {updated}</p>
        <h1 class="hero__heading">{hero.heading}</h1>
        <p class="hero__lead" set:html={hero.lead.replace('cited by AI', '<span class="squiggle">cited by AI</span>')}></p>
        <dl class="stats">
          {hero.stats.map((s) => (
            <div class="stats__item">
              <dt class="stats__value">{s.value}</dt>
              <dd class="stats__label">
                {s.label}
                {s.source && <span class="stats__src">{s.source}</span>}
              </dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <!-- ================= HOW TO USE ================= -->
    <section class="howto" aria-labelledby="howto-heading">
      <div class="container howto__grid">
        <div class="howto__intro">
          <p class="eyebrow">Mindset</p>
          <h2 id="howto-heading">{howToUse.heading}</h2>
          <p class="howto__lead">{howToUse.intro}</p>
          {howToUse.notes.map((n) => <p class="howto__note">{n}</p>)}
        </div>
        <ul class="legend">
          {howToUse.ratings.map((r) => (
            <li class={`legend__item legend--${r.key}`}>
              <span class="legend__dot" aria-hidden="true"></span>
              <span><strong>{r.label}</strong> — {r.desc}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ================= CONTENTS / PHASE NAV ================= -->
    <nav class="contents" aria-label="Checklist phases">
      <div class="container">
        <p class="eyebrow">Contents</p>
        <ol class="contents__list">
          {phases.map((p) => (
            <li>
              <a class="contents__link" href={`#${p.id}`} data-phase-link={p.id}>
                <span class="contents__num">{p.number}</span>
                <span class="contents__title">{p.title}</span>
                <span class="contents__count" data-phase-progress={p.id}>0/{p.items.length}</span>
              </a>
            </li>
          ))}
        </ol>
      </div>
    </nav>

    <!-- ================= PHASES ================= -->
    {phases.map((phase) => (
      <section class="phase" id={phase.id} data-phase-group={phase.id} aria-labelledby={`${phase.id}-heading`}>
        <div class="container">
          <header class="phase__head">
            <span class="phase__num" aria-hidden="true">{phase.number}</span>
            <div class="phase__headtext">
              <h2 id={`${phase.id}-heading`} class="phase__title">{phase.title}</h2>
              <p class="phase__blurb">{phase.blurb}</p>
            </div>
            <span class="phase__progress" data-phase-progress={phase.id} aria-hidden="true">0/{phase.items.length}</span>
          </header>
          <div class="phase__items">
            {phase.items.map((item) => <ChecklistItem item={item} />)}
          </div>
        </div>
      </section>
    ))}

    <!-- ================= DO-FIRST SHORTLIST ================= -->
    <section class="dofirst" aria-labelledby="dofirst-heading">
      <div class="container">
        <p class="eyebrow dofirst__eyebrow">Priority<img class="aster" src="/brand/asterisk.svg" alt="" aria-hidden="true" width="12" height="13" /></p>
        <h2 id="dofirst-heading">{doFirst.heading}</h2>
        <p class="dofirst__lead">{doFirst.intro}</p>
        <ul class="dofirst__list">
          {doFirst.items.map((d) => <li>{d}</li>)}
        </ul>
        <div class="dofirst__after">
          <p class="eyebrow">After launch</p>
          <p>{doFirst.afterLaunch}</p>
        </div>
      </div>
    </section>

    <!-- ================= FAQ ================= -->
    <FAQ />

    <!-- ================= ABOUT / METHODOLOGY ================= -->
    <section class="about" id="about" aria-labelledby="about-heading">
      <div class="container about__grid">
        <div>
          <p class="eyebrow">Why we made this</p>
          <h2 id="about-heading">{about.heading}</h2>
        </div>
        <div class="about__body">
          {about.body.map((para) => <p>{para}</p>)}
        </div>
      </div>
    </section>

    <!-- ================= REFERENCES ================= -->
    <section class="sources" aria-labelledby="sources-heading">
      <div class="container">
        <p class="eyebrow">Credited in full</p>
        <h2 id="sources-heading" class="sources__heading">References &amp; further reading</h2>

        <h3 class="sources__sub">The research behind the numbers</h3>
        <ul class="sources__list">
          {dataSources.map((s) => (
            <li>
              <a class="link" href={s.url} target="_blank" rel="noopener">{s.label}</a>
              {s.note && <span class="sources__note">{s.note}</span>}
            </li>
          ))}
        </ul>

        <h3 class="sources__sub">Webflow & SEO references</h3>
        <ul class="sources__list">
          {readingSources.map((s) => (
            <li>
              <a class="link" href={s.url} target="_blank" rel="noopener">{s.label}</a>
              {s.note && <span class="sources__note">{s.note}</span>}
            </li>
          ))}
        </ul>
      </div>
    </section>
  </main>

  <!-- ================= FOOTER =================
       Shared Milk Moon menu-column footer (identity block · link columns ·
       circular socials · hairline · legal), bound to THIS site's black/purple
       tokens. Keeps the site's own logo, tagline and "Built by" CTA; adds the
       three-tool cross-links. Social + legal URLs match the studio's live footer. -->
  <footer class="site-footer">
    <div class="container site-footer-inner">
      <div class="site-footer-identity">
        <img class="footer__logo" src="/brand/mms-logo.svg" alt="Milk Moon Studio" width="150" height="69" />
        <p class="footer__title">The Ultimate Webflow SEO &amp; AEO Checklist</p>
        <p class="footer__sub">A field guide for shipping Webflow sites that rank and get cited.</p>
        <a class="footer__cta" href="https://www.milkmoonstudio.com" target="_blank" rel="noopener">
          Built by Milk Moon Studio
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M7 17L17 7M17 7H8M17 7v9" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      <nav class="site-footer-columns" aria-label="Footer">
        <div class="site-footer-column">
          <span class="site-footer-heading">Studio</span>
          <a href="https://www.milkmoonstudio.com" target="_blank" rel="noopener">Milk Moon Studio</a>
          <a href="https://www.milkmoonstudio.com/blog" target="_blank" rel="noopener">Blog</a>
          <a href="https://www.milkmoonstudio.com/contact-us" target="_blank" rel="noopener">Contact</a>
          <a href="https://webflow.com/@Milk-Moon-Studio" target="_blank" rel="noopener">Webflow partner</a>
        </div>

        <div class="site-footer-column">
          <span class="site-footer-heading">Side projects</span>
          <a href="https://scan.milkmoonstudio.com" target="_blank" rel="noopener">Bot App&eacute;tit</a>
          <span class="site-footer-current">SEO &amp; AEO Checklist (you're here)</span>
          <a href="https://easing.milkmoonstudio.com" target="_blank" rel="noopener">GSAP Easing Showcase</a>
        </div>

        <div class="site-footer-column">
          <span class="site-footer-heading">Elsewhere</span>
          <a href="https://contra.com/jakes_van_eeden/work" target="_blank" rel="noopener">Portfolio</a>
          <a href="https://g.page/r/CaaR5v308b3uEAI/review" target="_blank" rel="noopener">Leave a review</a>
          <a href="mailto:jakes@milkmoonstudio.com?subject=Webflow%20SEO%20Checklist%20bug%20report&body=What%20happened%3A%0A%0A">Report a bug</a>
        </div>
      </nav>
    </div>

    <div class="container site-footer-socials">
      <a class="site-footer-social" href="https://www.instagram.com/milk_moon_studio/" target="_blank" rel="noopener" aria-label="Milk Moon Studio on Instagram">
        <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><rect x="2.5" y="2.5" width="15" height="15" rx="4" stroke="currentColor" stroke-width="1.5"></rect><circle cx="10" cy="10" r="4" stroke="currentColor" stroke-width="1.5"></circle><circle cx="14.2" cy="5.8" r="1" fill="currentColor"></circle></svg>
      </a>
      <a class="site-footer-social" href="https://www.linkedin.com/company/milk-moon-studio" target="_blank" rel="noopener" aria-label="Milk Moon Studio on LinkedIn">
        <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><rect x="2.5" y="2.5" width="15" height="15" stroke="currentColor" stroke-width="1.5"></rect><circle cx="6.2" cy="6.5" r="1" fill="currentColor"></circle><path d="M6.2 9v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path><path d="M10 15v-3.5c0-1.4 1-2.5 2.3-2.5s2 .9 2 2.3V15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path><path d="M10 9v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path></svg>
      </a>
      <a class="site-footer-social" href="https://twitter.com/MilkMoonStudio" target="_blank" rel="noopener" aria-label="Milk Moon Studio on X">
        <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 4l12 12M16 4L4 16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path></svg>
      </a>
      <a class="site-footer-social" href="https://www.facebook.com/milkmoonstudio" target="_blank" rel="noopener" aria-label="Milk Moon Studio on Facebook">
        <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M12.5 3.5h-2A3 3 0 0 0 7.5 6.5v2.5H5.5v3h2V17h3v-5h2.3l.4-3h-2.7v-2c0-.8.2-1.3 1.3-1.3h1.5z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"></path></svg>
      </a>
      <a class="site-footer-social" href="https://www.youtube.com/@milkmoonstudio" target="_blank" rel="noopener" aria-label="Milk Moon Studio on YouTube">
        <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><rect x="2.5" y="5" width="15" height="10" rx="2.5" stroke="currentColor" stroke-width="1.5"></rect><path d="M8.5 7.5v5l4-2.5z" fill="currentColor"></path></svg>
      </a>
      <a class="site-footer-social" href="https://vimeo.com/milkmoonstudio" target="_blank" rel="noopener" aria-label="Milk Moon Studio on Vimeo">
        <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 7c1-1 2.5-1.5 3 .5.4 1.6.7 3.4 1.4 3.4.8 0 2.2-2.2 2.4-3.2.3-1.4-.6-1.7-1.4-1.3 1-2.6 3.8-2.6 3.9.3.1 1.7-2 4.7-3.2 5.6-1 .7-2 .3-2.6-.8C5.9 12 5.6 9.7 5 9.2c-.3-.3-.7 0-1 .3z" stroke="currentColor" stroke-width="1.1" stroke-linejoin="round"></path></svg>
      </a>
      <a class="site-footer-social" href="https://medium.com/milk-moon-studio" target="_blank" rel="noopener" aria-label="Milk Moon Studio on Medium">
        <svg viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="6" cy="10" r="4" stroke="currentColor" stroke-width="1.4"></circle><ellipse cx="13" cy="10" rx="1.4" ry="4" stroke="currentColor" stroke-width="1.2"></ellipse><path d="M17 6.5v7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path></svg>
      </a>
    </div>

    <hr class="container site-footer-hairline" />

    <div class="container site-footer-legal">
      <span>&copy; Milk Moon Studio. Made for Webflow builders, in the Overberg.</span>
      <div class="site-footer-legal-links">
        <a href="https://www.milkmoonstudio.com/legal/privacy-policy" target="_blank" rel="noopener">Privacy policy</a>
        <a href="https://www.milkmoonstudio.com/legal/cookie-policy" target="_blank" rel="noopener">Cookie policy</a>
      </div>
    </div>
  </footer>

  <script>
    import '../scripts/motion.js';
    import '../scripts/progress.js';
  </script>
</Base>

<style>
  /* ---------------- HERO ---------------- */
  .hero { padding-block: clamp(3rem, 9vw, 7rem) clamp(2rem, 5vw, 3.5rem); }
  .hero .container { position: relative; }
  .hero__star {
    position: absolute;
    top: clamp(0.25rem, 2vw, 1.5rem);
    right: 0;
    width: clamp(26px, 4vw, 40px);
    height: auto;
    transform: rotate(-10deg);
    pointer-events: none;
  }
  .hero__eyebrow { margin-bottom: 1.5rem; }
  .dofirst__eyebrow { display: inline-flex; align-items: baseline; gap: 0.4rem; }
  .aster { width: 0.85em; height: auto; opacity: 0.9; }
  .hero__heading { margin-bottom: 1.6rem; }
  .hero__lead {
    font-size: clamp(1.05rem, 1.6vw, 1.3rem);
    color: var(--text-dim);
    line-height: 1.55;
  }
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-top: clamp(2.5rem, 5vw, 4rem);
    padding-top: 2.5rem;
    border-top: 1px solid var(--border);
  }
  .stats__value {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.2rem);
    color: var(--lilac);
    line-height: 1;
  }
  .stats__label { margin-top: 0.6rem; font-size: 0.85rem; color: var(--text-faint); line-height: 1.4; }
  .stats__src { display: block; margin-top: 0.35rem; font-size: 0.72rem; color: var(--purple); letter-spacing: 0.02em; }
  @media (max-width: 720px) {
    .stats { grid-template-columns: repeat(2, 1fr); gap: 1.75rem 1.5rem; }
  }

  /* ---------------- HOW TO USE ---------------- */
  .howto { padding-block: clamp(2.5rem, 6vw, 4.5rem); }
  .howto__grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: clamp(2rem, 5vw, 4.5rem); align-items: start; }
  .howto h2 { margin: 0.4rem 0 1.2rem; }
  .howto__lead { color: var(--text-dim); font-size: 1.05rem; line-height: 1.6; margin-bottom: 1.4rem; }
  .howto__note { color: var(--text-faint); font-size: 0.92rem; line-height: 1.6; margin-bottom: 0.9rem; }
  .legend { list-style: none; padding: 1.5rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); display: grid; gap: 1rem; }
  .legend__item { display: grid; grid-template-columns: auto 1fr; gap: 0.75rem; align-items: start; font-size: 0.9rem; color: var(--text-dim); line-height: 1.5; }
  .legend__item strong { color: var(--white); }
  .legend__dot { width: 0.7rem; height: 0.7rem; border-radius: 50%; margin-top: 0.35rem; background: var(--grey); }
  .legend--critical .legend__dot { background: var(--impact-critical); }
  .legend--high .legend__dot { background: var(--impact-high); }
  .legend--medium .legend__dot { background: var(--impact-medium); }
  .legend--low .legend__dot { background: var(--impact-low); }
  @media (max-width: 800px) { .howto__grid { grid-template-columns: 1fr; } }

  /* ---------------- CONTENTS ---------------- */
  .contents { padding-block: clamp(2rem, 5vw, 3.5rem); }
  .contents__list { list-style: none; counter-reset: none; display: grid; grid-template-columns: repeat(2, 1fr); gap: 0; margin-top: 1rem; border-top: 1px solid var(--border); }
  .contents__link {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 1rem 0.5rem;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: var(--text-dim);
    transition: color 0.18s var(--ease), background 0.18s var(--ease);
  }
  .contents__link:hover { color: var(--white); background: var(--bg-raised); }
  .contents__num { font-family: var(--font-display); font-size: 1.2rem; color: var(--purple); }
  .contents__title { font-weight: 500; }
  .contents__count { font-size: 0.8rem; color: var(--text-faint); font-variant-numeric: tabular-nums; }
  .contents__link.is-complete .contents__count { color: var(--lilac); }
  .contents__link.is-complete .contents__num { color: var(--lilac); }
  @media (max-width: 720px) { .contents__list { grid-template-columns: 1fr; } }

  /* ---------------- PHASE ---------------- */
  .phase { padding-block: clamp(2rem, 5vw, 3.5rem); }
  .phase__head {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: clamp(1rem, 3vw, 2rem);
    padding-bottom: 0.5rem;
  }
  .phase__num {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    color: var(--grey-dark);
    line-height: 0.8;
    -webkit-text-stroke: 1px var(--grey);
    color: transparent;
  }
  .phase__title { font-size: clamp(1.7rem, 3.5vw, 2.7rem); }
  .phase__blurb { color: var(--text-faint); margin-top: 0.35rem; font-size: 0.98rem; }
  .phase__progress {
    font-size: 0.85rem;
    color: var(--text-faint);
    font-variant-numeric: tabular-nums;
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.35rem 0.8rem;
    white-space: nowrap;
  }
  @media (max-width: 600px) {
    .phase__head { grid-template-columns: auto 1fr; }
    .phase__progress { grid-column: 1 / -1; justify-self: start; }
  }

  /* ---------------- DO FIRST ---------------- */
  .dofirst { padding-block: clamp(3rem, 7vw, 5.5rem); }
  .dofirst h2 { margin: 0.4rem 0 1rem; }
  .dofirst__lead { color: var(--text-dim); margin-bottom: 1.8rem; line-height: 1.6; }
  .dofirst__list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.85rem 2rem;
    counter-reset: df;
  }
  .dofirst__list li {
    position: relative;
    padding-left: 2rem;
    color: var(--text-dim);
    line-height: 1.5;
    counter-increment: df;
  }
  .dofirst__list li::before {
    content: counter(df);
    position: absolute;
    left: 0;
    top: 0;
    font-family: var(--font-display);
    color: var(--lilac);
    font-size: 1.1rem;
    line-height: 1.3;
  }
  .dofirst__after {
    margin-top: 2.5rem;
    padding: 1.5rem;
    border-left: 2px solid var(--purple);
    background: var(--bg-card);
    border-radius: 0 var(--radius) var(--radius) 0;
  }
  .dofirst__after p:last-child { color: var(--text-dim); line-height: 1.6; margin-top: 0.4rem; }
  @media (max-width: 720px) { .dofirst__list { grid-template-columns: 1fr; } }

  /* ---------------- ABOUT ---------------- */
  .about { padding-block: clamp(3rem, 7vw, 5.5rem); border-top: 1px solid var(--border); }
  .about__grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: clamp(2rem, 5vw, 4.5rem); align-items: start; }
  .about h2 { margin-top: 0.4rem; }
  .about__body { display: grid; gap: 1.1rem; }
  .about__body p { color: var(--text-dim); line-height: 1.65; }
  @media (max-width: 800px) { .about__grid { grid-template-columns: 1fr; } }

  /* ---------------- SOURCES ---------------- */
  .sources { padding-block: clamp(2rem, 5vw, 3.5rem); }
  .sources__heading { margin: 0.4rem 0 1.8rem; }
  .sources__sub {
    font-family: var(--font-body);
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin: 2rem 0 1rem;
  }
  .sources__sub:first-of-type { margin-top: 0; }
  .sources__list { list-style: none; display: grid; gap: 1rem; }
  .sources__list li { color: var(--text-faint); display: grid; gap: 0.2rem; }
  .sources__note { font-size: 0.85rem; color: var(--text-faint); line-height: 1.45; }

  /* ---------------- FOOTER ----------------
     Shared Milk Moon menu-column footer (see Bot Appétit's SiteFooter for the
     canonical shape), bound to THIS site's black/purple tokens. The band spans
     full width; inner rows use .container for the site's max-width + gutters. */
  .site-footer { background: var(--bg-raised); border-top: 1px solid var(--border); padding-block: clamp(2.5rem, 5vw, 3.5rem); margin-top: 2rem; }
  .site-footer-inner { display: flex; flex-wrap: wrap; gap: clamp(2rem, 5vw, 3.5rem); align-items: flex-start; justify-content: space-between; }
  .site-footer-identity { display: flex; flex-direction: column; align-items: flex-start; gap: 0.4rem; max-width: 24rem; }
  .footer__title { font-family: var(--font-display); font-size: 1.3rem; color: var(--white); }
  .footer__sub { color: var(--text-faint); font-size: 0.9rem; margin-top: 0.3rem; }
  .footer__logo { width: clamp(120px, 20vw, 158px); height: auto; margin-bottom: 1.1rem; }
  .footer__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.9rem;
    font-weight: 500;
    color: var(--black);
    background: var(--white);
    padding: 0.85rem 1.4rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: transform 0.18s var(--ease), background 0.18s var(--ease);
  }
  .footer__cta:hover { transform: translateY(-2px); background: var(--pale-yellow); }

  .site-footer-columns { display: flex; flex-wrap: wrap; gap: clamp(2.5rem, 6vw, 5rem); }
  .site-footer-column { display: flex; flex-direction: column; gap: 0.85rem; min-width: 9rem; }
  .site-footer-column a { color: var(--off-white); text-decoration: none; font-size: 0.9rem; }
  .site-footer-column a:hover { color: var(--pale-yellow); }
  .site-footer-current { color: var(--text-faint); font-size: 0.9rem; }
  .site-footer-heading { font-family: var(--font-display); font-size: 1rem; color: var(--text-faint); }

  .site-footer-socials { margin-top: clamp(2rem, 5vw, 3rem); display: flex; gap: 0.75rem; }
  /* Circular socials — the brand's sanctioned circle exception (BRAND.md), even
     though this site's default radius is square. */
  .site-footer-social {
